# Plantilla de variables de entorno de Luderis (frontend, Vite).
# Copiá este archivo a `.env` y completá los valores. NO subas tu `.env` real.
# Vite las resuelve en vite.config.js con `define` (ver ese archivo).

# Supabase — URL del proyecto y anon key (pública, va en el bundle)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_KEY=

# Email del admin (para el gate del panel de administración)
REACT_APP_ADMIN_EMAIL=

# Web Push — clave pública VAPID
REACT_APP_VAPID_PUBLIC=

# Mercado Pago / Stripe — public key del checkout (pública)
REACT_APP_STRIPE_PK=
